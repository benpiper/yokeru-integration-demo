# Copy to .env and fill in real values. Never commit .env.
# All env vars are namespaced YOKERU_*.

YOKERU_FHIR_BASE_URL=https://fhir-open.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d
YOKERU_YOKERU_API_URL=https://httpbin.org/post
YOKERU_DB_PATH=integration_state.db

YOKERU_HTTP_CONNECT_TIMEOUT_S=5
YOKERU_HTTP_READ_TIMEOUT_S=10

YOKERU_RETRY_MAX_ATTEMPTS=3
YOKERU_RETRY_MIN_WAIT_S=2
YOKERU_RETRY_MAX_WAIT_S=10

YOKERU_BREAKER_FAILURE_THRESHOLD=3
YOKERU_BREAKER_RESET_TIMEOUT_S=4

YOKERU_WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-string

YOKERU_LOG_LEVEL=INFO
YOKERU_LOG_FORMAT=json
